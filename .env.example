# Full API base URL including /bot/miniapp/api
# In development, leave unset — dev server proxies /bot/miniapp/api → localhost:8001
VITE_API_URL=https://api.yourdomain.com/bot/miniapp/api

# Brand customization (optional — defaults to "Cheeze Networks" / built-in logo)
VITE_BRAND_NAME=Cheeze Networks
VITE_BRAND_LOGO=

# Mirror failover: comma-separated list of ALL mirror origins (including this one).
# Current origin is excluded automatically at runtime.
# Leave empty to disable failover.
VITE_MIRRORS=https://web.yourdomain.com,https://yourrepo.vercel.app,https://user.github.io
