# Public URL of this site (used for SEO: canonical, og:url, sitemap)
# Set as Actions variable VITE_SITE_URL in GitHub → Settings → Variables
VITE_SITE_URL=https://www.cheezyvpn.uk

# Full API base URL including /bot/miniapp/api
# In development, leave unset — dev server proxies /bot/miniapp/api → localhost:8001
VITE_API_URL=https://api.yourdomain.com/bot/miniapp/api

# Brand customization (optional — defaults to "Cheeze Networks" / built-in logo)
VITE_BRAND_NAME=Cheeze Networks
VITE_BRAND_LOGO=

# Mirror failover: comma-separated list of ALL mirror origins (including this one).
# Current origin is excluded automatically at runtime.
# Leave empty to disable failover.
VITE_MIRRORS=https://web.yourdomain.com,https://yourrepo.vercel.app,https://user.github.io

# Telegram Login (optional — leave empty to hide the "Sign in with Telegram" button)
# Set VITE_TG_BOT_ID to the bot's numeric Client ID from BotFather.
# The domain must be whitelisted in BotFather: /setdomain → https://yourdomain.com
# Set as an Actions variable (NOT secret — this value is public).
# The bot token (Client Secret) is read from config.yml and stays server-side only.
VITE_TG_BOT_ID=
